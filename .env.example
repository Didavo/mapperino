# Docker Dev (host.docker.internal → Host-PostgreSQL via extra_hosts)
DATABASE_URL=xx

# Lokal ohne Docker (npm run dev):
# DATABASE_URL=xx

# Produktion – dedizierter Read-only-User (einmalig anlegen):
#   docker exec -it <postgres-container> psql -U scraper -d event_scraper
#   CREATE USER frontend_reader WITH PASSWORD 'SICHERES_PASSWORT';
#   GRANT CONNECT ON DATABASE event_scraper TO frontend_reader;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO frontend_reader;
# DATABASE_URL=

# Port (optional, Standard: 3000)
# PORT=3000
